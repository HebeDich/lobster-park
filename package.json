{
  "name": "lobster-park",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "packageManager": "pnpm@9.15.5",
  "scripts": {
    "bootstrap": "COREPACK_HOME=$PWD/.tmp/corepack corepack pnpm install --store-dir .tmp/pnpm-store",
    "dev": "COREPACK_HOME=$PWD/.tmp/corepack corepack pnpm -r --parallel dev",
    "build": "COREPACK_HOME=$PWD/.tmp/corepack corepack pnpm -r build",
    "test": "COREPACK_HOME=$PWD/.tmp/corepack corepack pnpm -r test",
    "lint": "COREPACK_HOME=$PWD/.tmp/corepack corepack pnpm -r lint",
    "generate:api": "COREPACK_HOME=$PWD/.tmp/corepack corepack pnpm --filter @lobster-park/web generate:api",
    "smoke": "COREPACK_HOME=$PWD/.tmp/corepack corepack pnpm build",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "db:migrate": "COREPACK_HOME=$PWD/.tmp/corepack corepack pnpm --filter @lobster-park/server prisma:migrate:deploy",
    "db:reset": "COREPACK_HOME=$PWD/.tmp/corepack corepack pnpm --filter @lobster-park/server prisma:migrate:reset",
    "db:seed": "COREPACK_HOME=$PWD/.tmp/corepack corepack pnpm --filter @lobster-park/server prisma:seed",
    "server:dev": "PORT=3301 COREPACK_HOME=$PWD/.tmp/corepack corepack pnpm --filter @lobster-park/server dev",
    "manual:up": "./scripts/start-manual-verification.sh",
    "manual:down": "./scripts/stop-manual-verification.sh",
    "web:dev": "VITE_SERVER_ORIGIN=${VITE_SERVER_ORIGIN:-http://127.0.0.1:3301} COREPACK_HOME=$PWD/.tmp/corepack corepack pnpm --filter @lobster-park/web dev",
    "smoke:api": "node scripts/smoke-api.mjs",
    "smoke:oidc": "node scripts/smoke-oidc.mjs",
    "smoke:config": "node scripts/smoke-config-flow.mjs",
    "smoke:realtime": "node scripts/smoke-realtime.mjs",
    "server:start:local": "./scripts/start-local-server.sh",
    "server:stop:local": "./scripts/stop-local-server.sh",
    "smoke:rbac": "node scripts/smoke-rbac.mjs",
    "smoke:jobs": "node scripts/smoke-jobs.mjs",
    "verify:full": "./scripts/verify-full.sh",
    "web:start:local": "./scripts/start-local-web.sh",
    "web:stop:local": "./scripts/stop-local-web.sh",
    "smoke:web": "node scripts/smoke-web.mjs",
    "smoke:container": "node scripts/smoke-container-runtime.mjs",
    "smoke:template-skill": "node scripts/smoke-template-skill.mjs",
    "smoke:openclaw-basic-config": "node scripts/smoke-openclaw-basic-config.mjs",
    "smoke:openclaw-channel-test": "node scripts/smoke-openclaw-channel-test.mjs",
    "smoke:openclaw-console": "node scripts/smoke-openclaw-console.mjs",
    "smoke:openclaw-pairing": "node scripts/smoke-openclaw-pairing.mjs",
    "smoke:openclaw-qr-status": "node scripts/smoke-openclaw-qr-status.mjs",
    "smoke:openclaw-qr-session": "node scripts/smoke-openclaw-qr-session.mjs",
    "smoke:openclaw-qr-logs": "node scripts/smoke-openclaw-qr-logs.mjs",
    "smoke:openclaw-qr-diagnostics": "node scripts/smoke-openclaw-qr-diagnostics.mjs",
    "smoke:openclaw-real-delivery": "node scripts/smoke-openclaw-real-delivery.mjs",
    "smoke:openclaw-acceptance": "node scripts/smoke-openclaw-acceptance.mjs",
    "smoke:openclaw-acceptance-center": "node scripts/smoke-openclaw-acceptance-center.mjs",
    "smoke:openclaw-acceptance-live": "node scripts/smoke-openclaw-acceptance-live.mjs",
    "openclaw:acceptance-live:example": "node scripts/openclaw-acceptance-live-example.mjs",
    "openclaw:acceptance-live:report": "node scripts/openclaw-acceptance-live-report.mjs",
    "openclaw:acceptance-live:index": "node scripts/openclaw-acceptance-live-index.mjs",
    "openclaw:real-delivery:example": "node scripts/openclaw-real-delivery-example.mjs",
    "smoke:platform-settings": "node scripts/smoke-platform-settings.mjs",
    "smoke:instance-audits": "node scripts/smoke-instance-audits.mjs",
    "smoke:notification-email": "node scripts/smoke-notification-email.mjs",
    "release:linux": "bash scripts/build-linux-release.sh",
    "release:linux:verify": "bash scripts/verify-linux-release.sh",
    "app:up": "docker compose -f docker-compose.yml -f docker-compose.app.yml up -d --build",
    "app:down": "docker compose -f docker-compose.yml -f docker-compose.app.yml down",
    "docker:config": "docker compose -f docker-compose.yml -f docker-compose.app.yml config",
    "e2e:install": "PLAYWRIGHT_BROWSERS_PATH=$PWD/.tmp/ms-playwright COREPACK_HOME=$PWD/.tmp/corepack corepack pnpm exec playwright install chromium",
    "e2e": "PLAYWRIGHT_BROWSERS_PATH=$PWD/.tmp/ms-playwright COREPACK_HOME=$PWD/.tmp/corepack corepack pnpm exec playwright test",
    "verify:full:e2e": "RUN_E2E=1 ./scripts/verify-full.sh",
    "openclaw:install:local": "./scripts/install-openclaw-local.sh",
    "openclaw:runtime-image:build": "docker build -f docker/openclaw-runtime/Dockerfile -t lobster-park-openclaw-runtime:dev .",
    "openclaw:runtime-image:inspect": "docker run --rm lobster-park-openclaw-runtime:dev lobster-openclaw-runtime-info"
  },
  "devDependencies": {
    "smtp-server": "^3.14.0",
    "ws": "^8.18.1",
    "@playwright/test": "^1.52.0"
  }
}
