NODE_ENV=production
PORT=3301
DATABASE_URL=postgresql://lobster:replace_me_before_first_start@127.0.0.1:55432/lobster_park
REDIS_URL=redis://127.0.0.1:56379
SECRET_MASTER_KEY=generate_a_64_char_hex_key_before_first_start
LOBSTER_DEFAULT_ADMIN_PASSWORD=replace_with_a_strong_admin_password
RUNTIME_BASE_PATH=/opt/lobster-park/runtimes
OPENCLAW_RUNTIME_MODE=container
OPENCLAW_CONTAINER_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_BIN=/usr/local/bin/openclaw
AUTH_DEMO_ENABLED=false
AUTH_COOKIE_SECURE=auto
WEB_APP_ORIGIN=http://127.0.0.1:3301
CORS_ORIGINS=http://127.0.0.1:3301
LP_POSTGRES_DB=lobster_park
LP_POSTGRES_USER=lobster
LP_POSTGRES_PASSWORD=replace_me_before_first_start
LP_POSTGRES_PORT=55432
LP_POSTGRES_IMAGE=postgres:15
LP_REDIS_PORT=56379
LP_REDIS_IMAGE=redis:7
