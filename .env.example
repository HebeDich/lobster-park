# Local development example only.
# For production, use `deploy/linux/install.sh`; it generates safer defaults and disables demo auth.
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:replace_me_for_public_example@127.0.0.1:5432/lobster_park
REDIS_URL=redis://127.0.0.1:6379
SECRET_MASTER_KEY=generate_a_64_char_hex_key_before_production_use
OIDC_ISSUER_URL=https://idp.example.com
OIDC_CLIENT_ID=lobster-park-web
ADMIN_EMAIL=admin@example.com
CORS_ORIGINS=http://localhost:5173
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
RUNTIME_BASE_PATH=.tmp/runtimes
OPENCLAW_BIN=openclaw
OPENCLAW_SIMULATE=false

OPENCLAW_RUNTIME_MODE=container
OPENCLAW_CONTAINER_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_CONTAINER_SIMULATE=false

AUTH_DEMO_ENABLED=true
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://127.0.0.1:3301/api/v1/auth/sso/callback
OIDC_SCOPES=openid profile email
AUTH_ACCESS_COOKIE_NAME=lp_access
AUTH_REFRESH_COOKIE_NAME=lp_refresh
AUTH_ACCESS_TTL=900
AUTH_REFRESH_TTL=604800
AUTH_OIDC_STATE_TTL=600
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_WRITE_MAX_REQUESTS=60
RATE_LIMIT_AUTH_MAX_REQUESTS=20
EMAIL_NOTIFICATIONS_ENABLED=true
EMAIL_TRANSPORT=log
EMAIL_DISPATCH_INTERVAL_MS=5000
EMAIL_MAX_RETRIES=3
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM=noreply@lobster-park.local
AUDIT_OUTBOX_DISPATCH_ENABLED=true
AUDIT_OUTBOX_DISPATCH_INTERVAL_MS=5000
AUDIT_OUTBOX_DISPATCH_BATCH_SIZE=100
AUDIT_OUTBOX_MAX_RETRIES=5
WEB_APP_ORIGIN=http://127.0.0.1:4173

OPENCLAW_REAL_DELIVERY_ENABLED=false
OPENCLAW_REAL_DELIVERY_INSTANCE_ID=ins_demo
OPENCLAW_REAL_DELIVERY_CHANNEL=
OPENCLAW_REAL_DELIVERY_TARGET=
OPENCLAW_REAL_DELIVERY_MESSAGE=
OPENCLAW_REAL_DELIVERY_MODEL_ID=model_default
OPENCLAW_REAL_DELIVERY_FIELDS_JSON=
OPENCLAW_REAL_DELIVERY_USER_EMAIL=admin@example.com

OPENCLAW_ACCEPTANCE_LIVE_ENABLED=false
OPENCLAW_ACCEPTANCE_LIVE_USER_EMAIL=admin@example.com
OPENCLAW_ACCEPTANCE_LIVE_TEMPLATE_ID=tpl_demo_01
OPENCLAW_ACCEPTANCE_LIVE_SPEC_CODE=S
OPENCLAW_ACCEPTANCE_LIVE_MODEL_PROVIDER=openai
OPENCLAW_ACCEPTANCE_LIVE_MODEL_NAME=gpt-4o-mini
OPENCLAW_ACCEPTANCE_LIVE_MODEL_SECRET_KEY=openai_api_key
OPENCLAW_ACCEPTANCE_LIVE_MODEL_API_KEY=
OPENCLAW_ACCEPTANCE_LIVE_TELEGRAM_BOT_TOKEN=
OPENCLAW_ACCEPTANCE_LIVE_TELEGRAM_TARGET=
OPENCLAW_ACCEPTANCE_LIVE_CONSOLE_MESSAGE=hello from live acceptance
OPENCLAW_ACCEPTANCE_LIVE_CHANNEL_MESSAGE=live acceptance channel test
OPENCLAW_ACCEPTANCE_LIVE_CHANNEL=telegram
OPENCLAW_ACCEPTANCE_LIVE_TARGET=
OPENCLAW_ACCEPTANCE_LIVE_FIELDS_JSON=
OPENCLAW_ACCEPTANCE_LIVE_FEISHU_APP_ID=
OPENCLAW_ACCEPTANCE_LIVE_FEISHU_APP_SECRET=
OPENCLAW_ACCEPTANCE_LIVE_FEISHU_TARGET=
